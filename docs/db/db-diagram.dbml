// Ticket-Agent PostgreSQL schema
// Paste into https://dbdiagram.io/d or import this file
// Source: docs/db-schema.md

Project TicketAgent {
  database_type: 'PostgreSQL'
  Note: '14 tables · Drizzle ORM · Render PostgreSQL'
}

// ─── Enums ───────────────────────────────────────────────────────────────────

Enum event_status {
  scheduled
  postponed
  cancelled
  completed
}

Enum competition_type {
  League
  Cup
}

Enum team_competition_status {
  active
  eliminated
  winner
}

Enum supplier_type {
  tickets
  hotels
  packages
  transport
  other
}

Enum supplier_origin {
  israeli
  international
}


Enum min_price_currency {
  EUR
  USD
  ILS
  GBP
}

// ─── Geography ───────────────────────────────────────────────────────────────

TableGroup geography {
  countries
  cities
}

Table countries {
  id int [pk, increment, note: 'serial PK exception']
  name text [not null, note: 'Hebrew']
  name_en text
  slug text [not null, unique]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table cities {
  id uuid [pk, default: `gen_random_uuid()`]
  slug text [not null, unique]
  name text [not null, note: 'Hebrew']
  name_en text
  country_id int [not null, ref: > countries.id]
  is_popular boolean [not null, default: false]
  image_url text
  seo_content json [note: '[{ title, content, order? }]']
  faqs json [note: '[{ question, answer, order? }]']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

// ─── Football core ─────────────────────────────────────────────────────────────

TableGroup football_core {
  competitions
  teams
  venues
  team_competitions
}

Table competitions {
  id uuid [pk, default: `gen_random_uuid()`]
  name text [not null, note: 'Hebrew']
  name_en text
  slug text [not null, unique]
  country_id int [not null, ref: > countries.id]
  parent_competition_id uuid [ref: > competitions.id, note: 'cup→league / phase hierarchy']
  logo_url text
  image_url text
  background_image text
  description text
  type competition_type [not null, default: 'League']
  is_popular boolean [not null, default: false]
  months text[] [note: 'YYYY-MM']
  seo_content json
  faqs json
  api_competition_id int [unique, note: 'API-Football ID']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table teams {
  id uuid [pk, default: `gen_random_uuid()`]
  name text [not null, note: 'Hebrew']
  name_en text
  code text [not null, note: '3-letter e.g. LIV']
  slug text [not null, unique]
  logo_url text
  shirt_image_url text
  image_url text
  background_image text
  primary_color text [note: '#RRGGBB']
  secondary_color text
  api_football_id int [unique]
  is_popular boolean [not null, default: false]
  seo_content json
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table venues {
  id uuid [pk, default: `gen_random_uuid()`]
  name text [not null, note: 'Hebrew']
  name_en text
  address text [note: 'Hebrew']
  address_en text
  capacity int
  image text
  map_url text [note: 'static thumbnail']
  map_svg_path text [note: 'SVG source path/URL']
  map_sections_data json [note: '{ viewBox, blocks[] }']
  api_football_id int [unique]
  is_popular boolean [not null, default: false]
  city_id uuid [ref: > cities.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table team_competitions {
  team_id uuid [not null, ref: > teams.id]
  competition_id uuid [not null, ref: > competitions.id]
  season text [not null, note: 'e.g. 2024/2025']
  status team_competition_status [not null, default: 'active']
  is_current boolean [not null, default: true, note: 'active league tier']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (team_id, competition_id, season) [pk]
    (competition_id, season)
    (team_id, season, is_current)
  }
}

// ─── Events ────────────────────────────────────────────────────────────────────

TableGroup events {
  football_events
  concert_events
}

Table football_events {
  id uuid [pk, default: `gen_random_uuid()`]
  date timestamp [not null]
  status event_status [not null, default: 'scheduled']
  rescheduled_from uuid [ref: > football_events.id]
  competition_id uuid [not null, ref: > competitions.id]
  home_team_id uuid [ref: > teams.id]
  away_team_id uuid [ref: > teams.id]
  venue_id uuid [not null, ref: > venues.id]
  home_team_name text [note: 'TBD placeholder only']
  away_team_name text
  has_tbd_team boolean [not null, default: false]
  round text
  slug text [not null, unique]
  round_number int
  tags text[]
  is_hot boolean [not null, default: false]
  api_football_external_id int [unique]
  min_price_amount decimal(10,2)
  min_price_currency min_price_currency
  min_price_sorting_ils decimal(10,2) [note: 'sort-only']
  min_price_updated_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (status, date)
    (competition_id, date)
    (home_team_id, date)
    (away_team_id, date)
    (venue_id, date)
    (is_hot, date)
    min_price_sorting_ils
    rescheduled_from
  }
}

Table artists {
  id uuid [pk, default: `gen_random_uuid()`]
  name text [not null, unique, note: 'Hebrew']
  name_en text
  image_url text [not null]
  banner_url text
  description text
  slug text [not null, unique]
  is_featured boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table concert_events {
  id uuid [pk, default: `gen_random_uuid()`]
  slug text [not null, unique]
  artist_id uuid [not null, ref: > artists.id]
  tour_name text
  date timestamp [not null]
  venue_id uuid [not null, ref: > venues.id]
  city_id uuid [not null, ref: > cities.id]
  status event_status [not null, default: 'scheduled']
  rescheduled_from uuid [ref: > concert_events.id]
  is_hot boolean [not null, default: false]
  tags text[]
  min_price_amount decimal(10,2)
  min_price_currency min_price_currency
  min_price_sorting_ils decimal(10,2) [note: 'sort-only']
  min_price_updated_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (city_id, date)
    (venue_id, date)
    (status, date)
    (is_hot, date)
    min_price_sorting_ils
    rescheduled_from
  }
}

// ─── Suppliers & lazy-update mappings ──────────────────────────────────────────

TableGroup suppliers_and_mappings {
  suppliers
  team_supplier_mappings
  venue_supplier_mappings
  football_event_supplier_mappings
  concert_event_supplier_mappings
}

Table suppliers {
  id uuid [pk, default: `gen_random_uuid()`]
  name text [not null, unique, note: 'Hebrew']
  name_en text
  slug text [not null, unique]
  type supplier_type
  origin supplier_origin
  description text
  image_url text
  website_url text
  affiliate_link_base text
  supplier_countries text[] [note: 'ISO codes']
  supplier_competitions text[]
  api_football_id int
  internal_code text
  external_rating json [note: '{ rating, url, provider }']
  contact_info json
  sync_config json [note: 'schedule only']
  is_active boolean [not null, default: true]
  deactivated_at timestamp
  last_successful_sync_at timestamp
  priority int [not null, default: 0]
  metadata json
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table team_supplier_mappings {
  id uuid [pk, default: `gen_random_uuid()`]
  team_id uuid [not null, ref: > teams.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  supplier_team_name text
  supplier_external_id text [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (supplier_id, supplier_external_id)
    team_id
  }
}

Table venue_supplier_mappings {
  id uuid [pk, default: `gen_random_uuid()`]
  venue_id uuid [not null, ref: > venues.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  supplier_venue_name text
  supplier_external_id text [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (supplier_id, supplier_external_id)
    venue_id
  }
}

Table football_event_supplier_mappings {
  id uuid [pk, default: `gen_random_uuid()`]
  football_event_id uuid [not null, ref: > football_events.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  supplier_external_id text [not null]
  metadata json
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (supplier_id, supplier_external_id)
    football_event_id
  }
}

Table concert_event_supplier_mappings {
  id uuid [pk, default: `gen_random_uuid()`]
  concert_event_id uuid [not null, ref: > concert_events.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  supplier_external_id text [not null]
  metadata json
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    (supplier_id, supplier_external_id)
    concert_event_id
  }
}
